{
  "name": "se-2",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "cli",
    "sdk"
  ],
  "scripts": {
    "account": "npm run foundry:account",
    "account:generate": "npm run foundry:generate",
    "account:import": "npm run foundry:account-import",
    "account:reveal-pk": "npm run account:reveal-pk -w @se-2/foundry",
    "chain": "npm run foundry:chain",
    "compile": "npm run foundry:compile",
    "deploy": "npm run foundry:deploy",
    "flatten": "npm run foundry:flatten",
    "fork": "npm run foundry:fork",
    "format": "npm run next:format && npm run foundry:format",
    "foundry:account": "npm run account -w @se-2/foundry",
    "foundry:account-import": "npm run account:import -w @se-2/foundry",
    "foundry:chain": "npm run chain -w @se-2/foundry",
    "foundry:clean": "npm run clean -w @se-2/foundry",
    "foundry:compile": "npm run compile -w @se-2/foundry",
    "foundry:deploy": "npm run deploy -w @se-2/foundry",
    "foundry:deploy-verify": "npm run deploy:verify -w @se-2/foundry",
    "foundry:flatten": "npm run flatten -w @se-2/foundry",
    "foundry:fork": "npm run fork -w @se-2/foundry",
    "foundry:format": "npm run format -w @se-2/foundry",
    "foundry:generate": "npm run account:generate -w @se-2/foundry",
    "foundry:lint": "npm run lint -w @se-2/foundry",
    "foundry:test": "npm run test -w @se-2/foundry",
    "foundry:verify": "npm run verify -w @se-2/foundry",
    "generate": "npm run foundry:generate",
    "postinstall": "husky install",
    "ipfs": "npm run ipfs -w @se-2/nextjs",
    "lint": "npm run next:lint && npm run foundry:lint",
    "next:build": "npm run build -w @se-2/nextjs",
    "next:check-types": "npm run check-types -w @se-2/nextjs",
    "next:format": "npm run format -w @se-2/nextjs",
    "next:lint": "npm run lint -w @se-2/nextjs",
    "next:serve": "npm run serve -w @se-2/nextjs",
    "precommit": "lint-staged",
    "start": "npm run dev -w @se-2/nextjs",
    "test": "npm run foundry:test",
    "vercel": "npm run vercel -w @se-2/nextjs",
    "vercel:login": "npm run vercel:login -w @se-2/nextjs",
    "vercel:yolo": "npm run vercel:yolo -w @se-2/nextjs",
    "verify": "npm run foundry:verify"
  },
  "devDependencies": {
    "husky": "~9.1.6",
    "lint-staged": "~13.2.2"
  },
  "engines": {
    "node": ">=20.18.3"
  },
  "overrides": {
    "viem": "2.39.0",
    "prettier": "~3.5.3"
  }
}
