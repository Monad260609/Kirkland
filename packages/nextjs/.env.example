# NextJS environment variables
# Copy this file to .env.local and fill in the values

# Wallet private key of the DataCache contract owner (the deployer)
# Used by API routes to write results on-chain
# Get it with: yarn account:reveal-pk
BACKEND_PRIVATE_KEY=0x...

# DataCache contract address on Monad testnet
# Filled automatically after deploy, or copy from deployedContracts.ts
DATACACHE_ADDRESS=0x...

# Groq API key (for AI queries — optional, get one at https://console.groq.com)
GROQ_API_KEY=

# WalletConnect project ID (optional)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
