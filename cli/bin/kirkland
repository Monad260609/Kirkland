#!/bin/sh
# Follow symlinks to find the real script location (npm link creates symlinks)
SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
  DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  case "$SCRIPT" in
    /*) ;;
    *)  SCRIPT="$DIR/$SCRIPT" ;;
  esac
done
DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
exec npx tsx "$DIR/../src/index.ts" "$@"
